# Server Configuration
PORT=3000
NODE_ENV=production

# Database (Railway or Local PostgreSQL)
# Railway: DATABASE_URL is auto-generated by Railway
# Local: postgresql://user:password@localhost:5432/railway
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/railway

# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_aqui_segura_123

# Frontend URL (Railway domain or localhost)
FRONTEND_URL=https://productflow-frontend.up.railway.app
# Or for local development: http://localhost:5173
